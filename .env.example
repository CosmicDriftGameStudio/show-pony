# show-pony local dev. Copy to .env — the defaults match docker-compose.yml,
# so `docker compose up -d` gives you a Postgres + Redis these point at.
DATABASE_URL=postgres://showpony:showpony@localhost:5432/show_pony_dev
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-secret-change-me-at-least-32-bytes
TEST_DATABASE_URL=postgresql://showpony:showpony@localhost:5432/show_pony_dev
