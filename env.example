# show-pony local dev. Copy to .env — the defaults match docker-compose.yml,
# so `docker compose up -d` gives you a Postgres + Redis these point at.
DATABASE_URL=postgres://showpony:showpony@localhost:5432/show_pony_dev
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-jwt-secret-change-me-in-prod
TEST_DATABASE_URL=postgresql://showpony:showpony@localhost:5432/show_pony_dev

# Optional — Stripe test mode (leave unset to boot without checkout).
# Use real sk_test_/price_ IDs from your Stripe dashboard to try upgrades locally.
# billingLive stays off until sysadmin flips it in Platform → Stripe settings.
# STRIPE_API_KEY=sk_test_replace_me
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
# STRIPE_PRICE_STARTER=price_replace_me_starter
# STRIPE_PRICE_PRO=price_replace_me_pro
