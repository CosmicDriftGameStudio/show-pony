{
  "name": "show-pony",
  "description": "Lightweight guest list / event RSVP — Kumiko sample app. Make an event, share the link, see who's coming.",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "author": "Marc Frost <marc@cosmicdriftgamestudio.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CosmicDriftGameStudio/show-pony.git"
  },
  "scripts": {
    "dev": "PORT=4180 bun run kumiko-dev bin/server.ts",
    "build": "bun kumiko-build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun --config=bunfig.ci.toml test --dots",
    "test:integration": "bun --env-file=.env test src/__tests__/*.integration.test.ts",
    "test:integration:ci": "bun test src/__tests__/*.integration.test.ts",
    "screenshots": "bunx --bun playwright test --config=playwright.screenshots.config.ts"
  },
  "dependencies": {
    "@cosmicdrift/kumiko-bundled-features": "^0.125.2",
    "@cosmicdrift/kumiko-dev-server": "^0.125.2",
    "@cosmicdrift/kumiko-framework": "^0.125.2",
    "@cosmicdrift/kumiko-renderer": "^0.125.2",
    "@cosmicdrift/kumiko-renderer-web": "^0.125.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4.3.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@cosmicdrift/kumiko-framework": "0.125.2",
    "@cosmicdrift/kumiko-bundled-features": "0.125.2",
    "@cosmicdrift/kumiko-dev-server": "0.125.2",
    "@cosmicdrift/kumiko-renderer": "0.125.2",
    "@cosmicdrift/kumiko-renderer-web": "0.125.2",
    "@cosmicdrift/kumiko-headless": "0.125.2",
    "@cosmicdrift/kumiko-dispatcher-live": "0.125.2"
  }
}
